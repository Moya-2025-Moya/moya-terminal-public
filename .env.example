# moya.terminal env — copy to .env.local and fill in.
# NEXT_PUBLIC_* are exposed to the browser. Everything else is server-only.

# --- Access gate ---
# Single password for the whole terminal (middleware-enforced). Server-only.
TERMINAL_PASSWORD=

# --- Supabase (shared data layer) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, for sync/writes (do NOT prefix with NEXT_PUBLIC):
SUPABASE_SERVICE_ROLE_KEY=

# --- Alchemy RPC (wallet transports) ---
# Required for wallet connect / read-only RPC. Get a free key at alchemy.com.
NEXT_PUBLIC_ALCHEMY_KEY=
# Or override individual chains:
# NEXT_PUBLIC_RPC_ETHEREUM=
# NEXT_PUBLIC_RPC_ARBITRUM=
# NEXT_PUBLIC_RPC_BNB=
# NEXT_PUBLIC_RPC_BASE=
# NEXT_PUBLIC_RPC_SOLANA=

# --- Droplet Infra API (Bucket 2.5) ---
INFRA_API_URL=https://your-infra-host.example.com
INFRA_API_TOKEN=

# --- DeFi cache: zerion-fetcher read API (Bucket 1) ---
# Reuses INFRA_API_TOKEN as the bearer token.
DEFI_API_URL=http://YOUR_INFRA_HOST:3002

# --- Polymarket CLOB proxy (Bucket 2) ---
# Transparent reverse proxy to clob.polymarket.com via the NL droplet.
# Reuses INFRA_API_TOKEN as the bearer token.
POLYMARKET_PROXY_URL=http://YOUR_INFRA_HOST:3003

# --- Zerion (DeFi data source, Bucket 1 + on-chain part of Bucket 3) ---
ZERION_API_KEY=

# --- CEX read-only (Bucket 3) ---
HYPERLIQUID_API_KEY=
ASTER_API_KEY=
# BINANCE_API_KEY=   # reserved

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=
